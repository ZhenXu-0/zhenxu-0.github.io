---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"
const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hey there 👋</div>
    <div class="text-3xl font-bold">I'm Zhen Xu</div>

    <div class="py-2 mt-8">
      <p class="text-lg">
        I’m a Ph.D. student in Cognitive Science in Education at Columbia University. My research centers on responsible and human-centered AI in education. 
      </p>
    </div>

    <div class="py-2 mt-2 text-lg space-y-4">
      <p>
       Specifically, I draw on perspectives from cognitive science, psychology, learning science, and assessment approaches in the social sciences to pursue two complementary goals: understanding how AI is reshaping human cognition, decision-making, and interaction, and developing methods to evaluate and improve existing AI systems for more effective and reliable use.

      <p>
        I’ve been fortunate to be advised by Professor <a href="https://renzheyu.com/" target="_blank" class="font-semibold underline">Renzhe Yu</a>
       at Columbia University. Previously, I received my master’s degree from Beijing Normal University in STEM Education, where I was advised by Professor Ping Zhang.

       <p>
       Recently, my research has focused on three main areas:
      </p>

      <ol class="list-decimal list-inside space-y-2">
        <li>
          <b>AI and the Transformation of Higher Education.</b> I study the broader impact of AI on learners’ cognitive engagement, social interaction, and the skills and competencies emphasized in higher education through large-scale behavioral and interaction log analysis.
        </li>
        <li>
          <b>AI as a Cognitive Partner and Pedagogical Assistant.</b> I develop the evaluation framework to assess the pedagogical capabilities of AI systems, and draw on learning sciences and pedagogical theory to design AI agents that can better support complex problem-solving.
        </li>
        <li>
          <b>Evaluation Paradigms for Human-AI Collaboration Tasks.</b> I investigate evaluation methods for human-AI collaboration tasks, with the goal of moving beyond simple accuracy-based metrics toward more reliable and explainable assessment paradigms.
        </li>
      </ol>

    </div>
  </div>

<div class="mt-10">
  <h2 class="text-2xl font-semibold mb-2">📢 News</h2>
  <ul class="list-disc pl-6 text-base space-y-1 leading-relaxed">
    <li>2025.07 – I will attend AIED, EDM, and L@S in July 2025 in Perlamo, Italy. Happy to connect if you'll be there too!</li>
    <li>2025.04 – I will give an online talk as a Guest Speaker and Panelist at the Educational Technology Sub-Forum of the 16th China Education Symposium at Harvard University.</li>
    <li>2025.03 – I will give an online talk as a Guest Speaker at the AI Application Sub-Forum of Columbia University Teachers College China-US Education Forum.</li>
    <li>2025.03 – I will present a collection of work from our lab at the AI in Education: Research and Practice session, part of the Columbia AI Summit.</li>
    <li>2024.11 – Our paper “Intersectional inequalities in asynchronous academic communication” won Best Student Paper Awards at SCiP 2024🏆.</li>
    <li>2024.09 – I will start my PhD in Cognitive Science at Teachers College, Columbia University!</li>
  </ul>
</div>

  <div class="mt-20" id="projects">
    <h2 class="text-2xl font-semibold mb-2">💡 Publications</h2>
   <ul class="list-disc pl-6 text-base space-y-2 leading-relaxed">
    2025.07 – I will attend AIED, EDM, and L@S in July 2025 in Perlamo, Italy. Happy to connect if you'll be there too!</li>
    2025.04 – I will give an online talk as a Guest Speaker and Panelist at the Educational Technology Sub-Forum of the 16th China Education Symposium at Harvard University.</li>
    2025.03 – I will give an online talk as a Guest Speaker at the AI Application Sub-Forum of Columbia University Teachers College China-US Education Forum.</li>
    2025.03 – I will present a collection of work from our lab at the AI in Education: Research and Practice session, part of the Columbia AI Summit.</li>
    2024.11 – Our paper “Intersectional inequalities in asynchronous academic communication” won Best Student Paper Awards at SCiP 2024🏆.</li>
    2024.09 – I will start my PhD in Cognitive Science at Teachers College, Columbia University!</li>
  </ul>
  </div>

  <HorizontalCard
    title="Pedagogy-Based Evaluation Framework of Virtual Teaching Assistants"
    img="/VTA.png"
    author="Siyan Li, Zhen Xu, Vethavikashini Chithrra Raghuram, Xuanming Zhang, Renzhe Yu, Zhou Yu"
    desc="We developed a pedagogically grounded evaluation framework for Virtual Teaching Assistants (VTAs) in asynchronous forums and identified effective modeling approaches and key generalization challenges."
    url="#"
    badge="AIED25 Workshop"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Evaluating 21st-Century Competencies in Higher-Edu Curricula with LLMs: Benchmarking and Targeted Prompting Strategies"
    img="/JLA.png"
    author="Zhen Xu, XinGuan, Chenxi Shi, Qinhao Chen, Renzhe Yu"
    desc="We investigated how LLMs can support 21st-century competency analytics in higher education by benchmarking four models against a manually annotated dataset, and we proposed a prompting strategy (Curricular CoT) that modestly improves accuracy and reduces hallucinations."
    url="#"
    badge="Under Review"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="From Course to Skill: Evaluating LLM Performance in Curricular Analytics"
    img="/AIED.png"
    author="Zhen Xu, Xinjin Li, Yingqi Huan, Veronica Minaya, Renzhe Yu"
    desc="We systematically evaluate LLMs’ capabilities on skill extraction task in Curricular Analytics, benchmarking their performance against traditional NLP approaches, and examining how model performance varies across off-the-shelf and task-tailored strategies to offer practical guidance for integrating LLMs into Curricular Analytics workflows."
    url="#"
    badge=AIED25
  />
